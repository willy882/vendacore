# ──────────────────────────────────────────────────────────────
# VendaCore Backend — Variables de Entorno
# Copia este archivo como .env para desarrollo local
# En producción (Railway), configura estas variables en el dashboard
# ──────────────────────────────────────────────────────────────

# APP
NODE_ENV=production
PORT=4000

# BASE DE DATOS — Neon PostgreSQL
# Formato: postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# JWT — Cambia estos valores en producción (mínimo 32 caracteres aleatorios)
JWT_SECRET=CAMBIA_ESTO_A_UN_SECRETO_SEGURO_EN_PRODUCCION
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=CAMBIA_ESTO_A_OTRO_SECRETO_SEGURO_EN_PRODUCCION
JWT_REFRESH_EXPIRES=7d

# BCRYPT
BCRYPT_ROUNDS=12

# CORS — URLs del frontend separadas por coma
# Ejemplo: http://localhost:3000,https://tu-app.vercel.app
CORS_ORIGIN=http://localhost:3000,https://tu-app.vercel.app

# SUNAT / PSE — Nubefact (facturación electrónica)
NUBEFACT_TOKEN=TU_TOKEN_NUBEFACT
NUBEFACT_API_URL=https://api.nubefact.com/api/v1
NUBEFACT_RUC=TU_RUC

# ALMACENAMIENTO — Supabase Storage
STORAGE_BUCKET=vendacore-docs
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=TU_SUPABASE_ANON_KEY

# EMAIL — SMTP para envío de comprobantes
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password_de_gmail
SMTP_FROM=VendaCore <noreply@vendacore.app>
